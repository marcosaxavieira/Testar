@page
@using AgenciaTurismo.Pages.Reservas
@model AgenciaTurismo.Pages.Reservas.CreateModel

@{
    ViewData["Title"] = "Nova Reserva";
}

<style>
    body {
        font-family: 'Segoe UI', Roboto, sans-serif;
        background-color: #f4f6f9;
    }

    .card {
        background-color: white;
        border-radius: 8px;
        padding: 30px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.05);
        margin-top: 30px;
        width: 50%;
        margin-left: auto;
        margin-right: auto;
    }

    .card-title {
        font-size: 1.8rem;
        font-weight: 600;
        color: #343a40;
        margin-bottom: 20px;
    }

    .form-group {
        margin-bottom: 15px;
    }

    .form-control.date-input {
        width: 160px;
    }

    .btn-acoes {
        display: flex;
        gap: 10px;
        margin-top: 10px;
    }

    .btn-salvar, .btn-voltar {
        color: #fff;
        background-color: #0a58ca;
        border: none;
        padding: 8px 20px;
        border-radius: 6px;
        font-weight: 500;
        transition: all 0.3s ease;
        text-decoration: none;
    }

        .btn-salvar:hover, .btn-voltar:hover {
            background-color: #084298;
        }
</style>

<div class="card">
    <h2 class="card-title">Nova Reserva</h2>

    <form method="post">
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <div class="form-group">
            <label asp-for="Reserva.ClienteId" class="control-label">Cliente</label>
            <select asp-for="Reserva.ClienteId" class="form-control" asp-items="ViewBag.ClienteId">
                <option value="">Selecione um cliente</option>
            </select>
            <span asp-validation-for="Reserva.ClienteId" class="text-danger"></span> 
        </div>

        <div class="form-group">
            <label asp-for="Reserva.PacoteTuristicoId" class="control-label">Pacote Turístico</label>
            <select asp-for="Reserva.PacoteTuristicoId" class="form-control" asp-items="ViewBag.PacoteTuristicoId">
                <option value="">Selecione um pacote</option>
            </select>
            <span asp-validation-for="Reserva.PacoteTuristicoId" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="Reserva.DataReserva" class="control-label">Data da Reserva</label>
            <input asp-for="Reserva.DataReserva" class="form-control date-input" type="date" />
            <span asp-validation-for="Reserva.DataReserva" class="text-danger"></span>
        </div>

        <div class="btn-acoes">
            <button type="submit" class="btn-salvar">Salvar</button>
            <a asp-page="Index" class="btn-voltar">Voltar</a>
        </div>
    </form>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
