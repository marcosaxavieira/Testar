@page
@using AgenciaTurismo.Pages.Destinos
@model AgenciaTurismo.Pages.Destinos.CreateModel

@{
    ViewData["Title"] = "Incluir Destino";
}

<style>
    body {
        font-family: 'Segoe UI', Roboto, sans-serif;
        background-color: #a3b0bc;
        color: #212529;
    }

    .create-container {
        background-color: rgba(255, 255, 255, 0.6);
        border-radius: 12px;
        padding: 40px;
        margin: 50px auto;
        max-width: 600px;
        box-shadow: 0 4px 16px rgba(0, 0, 0, 0.1);
        backdrop-filter: blur(4px);
        text-align: left;
    }

    .create-title {
        font-size: 1.8rem;
        font-weight: 600;
        color: #0a58ca;
        margin-bottom: 30px;
    }

    .form-group {
        margin-bottom: 20px;
    }

    label {
        font-weight: 600;
        color: #495057;
        margin-bottom: 6px;
        display: block;
    }

    input.form-control {
        border-radius: 6px;
        padding: 8px 12px;
        font-size: 1rem;
        background-color: #f8f9fa;
        border: 1px solid #ced4da;
        color: #212529;
    }

    .btn-outline-azul-escuro {
        color: #0a58ca;
        border: 1px solid #0a58ca;
        background-color: transparent;
        transition: all 0.3s ease;
        font-weight: 500;
        border-radius: 8px;
        padding: 6px 14px;
        text-decoration: none;
    }

        .btn-outline-azul-escuro:hover {
            background-color: #0a58ca;
            color: white;
        }

    .action-buttons {
        margin-top: 30px;
        display: flex;
        gap: 10px;
    }

    .text-danger {
        color: #dc3545;
    }
</style>

<div class="create-container">
    <h2 class="create-title">Incluir Destino</h2>

    <form method="post">
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <div class="form-group">
            <label asp-for="Destino.Cidade">Cidade:</label>
            <input asp-for="Destino.Cidade" class="form-control" />
            <span asp-validation-for="Destino.Cidade" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="Destino.Pais">País:</label>
            <input asp-for="Destino.Pais" class="form-control" />
            <span asp-validation-for="Destino.Pais" class="text-danger"></span>
        </div>

        <div class="action-buttons">
            <input type="submit" value="Salvar" class="btn btn-outline-azul-escuro" />
            <a asp-page="Index" class="btn btn-outline-azul-escuro">Voltar</a>
        </div>
    </form>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
