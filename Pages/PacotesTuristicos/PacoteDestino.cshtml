@page "{id:int}"
@using AgenciaTurismo.Pages.PacotesTuristicos
@model AgenciaTurismo.Pages.PacotesTuristicos.PacoteDestinoModel

@{
    ViewData["Title"] = "Destinos do Pacote";
}

<style>
    body {
        font-family: 'Segoe UI', Roboto, sans-serif;
        background-color: #f4f6f9;
    }

    .card {
        background-color: white;
        border-radius: 8px;
        padding: 30px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.05);
        margin-top: 30px;
    }

    .card-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 20px;
    }

    .card-title {
        font-size: 1.8rem;
        font-weight: 600;
        color: #343a40;
        margin: 0;
    }

    .btn-adicionar, .btn-ok {
        color: #0a58ca;
        border: 1px solid #0a58ca;
        background-color: transparent;
        transition: all 0.3s ease;
        font-weight: 500;
        border-radius: 8px;
        padding: 6px 14px;
        text-decoration: none;
    }

    .btn-outline-azul-escuro {
        color: #0a58ca;
        background-color: transparent;
        transition: all 0.3s ease;
        font-weight: 500;
        border-radius: 6px;
        border: none;
    }

        .btn-adicionar:hover, .btn-ok:hover {
            background-color: #0a58ca;
            color: white;
        }

    .table th, .table td {
        vertical-align: middle;
    }

    .table thead {
        background-color: #e9ecef;
    }

    .table th {
        font-weight: 600;
        color: #495057;
    }

    .table td {
        color: #212529;
    }

    .form-inline {
        display: flex;
        gap: 10px;
        margin-bottom: 20px;
    }
</style>

<div class="container">
    <div class="card">
        <!-- Título e botão Adicionar -->
        <div class="card-header">
            <h2 class="card-title">@Model.Pacote.Titulo</h2>
            <form method="post" asp-page-handler="MostrarSelecao">
                <button type="submit" class="btn btn-adicionar">Adicionar</button>
            </form>
        </div>

        <!-- Campo de seleção e botão Ok -->
        @if (Model.MostrarSelecao)
        {
            <form method="post" class="form-inline" asp-page-handler="AdicionarDestino">
                <select asp-for="DestinoSelecionadoId" asp-items="Model.DestinosSelectList" class="form-control">
                    <option value="">Selecione um destino</option>
                </select>
                <button type="submit" class="btn btn-ok">Ok</button>
            </form>
        }

        <!-- Lista de destinos -->
        <div class="table-responsive">
            <table class="table table-hover">
                <thead>
                    <tr>
                        <th>Destino</th>
                        <th class="text-center">Ações</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var destino in Model.Pacote.Destinos)
                    {
                        <tr>
                            <td>@($"{destino.Cidade} - {destino.Pais}")</td>
                            <td class="text-center">
                                <form method="post" asp-page-handler="Delete" asp-route-id="@Model.Pacote.Id" asp-route-destinoId="@destino.Id">
                                    <button type="submit" class="btn btn-outline-azul-escuro btn-sm">Remover</button>

                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
