@page
@using AgenciaTurismo.Pages.Clientes
@model AgenciaTurismo.Pages.Clientes.EditModel

@{
    ViewData["Title"] = "Editar Cliente";
}

<style>
    body {
        font-family: 'Segoe UI', Roboto, sans-serif;
        background-color: #a3b0bc; /* azul acinzentado escurecido */
        color: #212529;
    }

    .edit-container {
        background-color: rgba(255, 255, 255, 0.6); /* box translúcido */
        border-radius: 12px;
        padding: 40px;
        margin: 50px auto;
        max-width: 600px;
        box-shadow: 0 4px 16px rgba(0, 0, 0, 0.1);
        backdrop-filter: blur(4px);
        text-align: left;
    }

    .edit-title {
        font-size: 1.8rem;
        font-weight: 600;
        color: #0a58ca;
        margin-bottom: 30px;
    }

    .form-group {
        margin-bottom: 20px;
    }

    label {
        font-weight: 600;
        color: #495057;
        margin-bottom: 6px;
        display: block;
    }

    input.form-control {
        border-radius: 6px;
        padding: 8px 12px;
        font-size: 1rem;
        background-color: #f8f9fa;
        border: 1px solid #ced4da;
        color: #212529;
    }

    .btn-outline-azul-escuro {
        color: #0a58ca;
        border: 2px solid #0a58ca;
        background-color: transparent;
        transition: all 0.3s ease;
        font-weight: 500;
        border-radius: 6px;
        padding: 6px 14px;
        text-decoration: none;
    }

        .btn-outline-azul-escuro:hover {
            background-color: #0a58ca;
            color: white;
        }

    .action-buttons {
        margin-top: 30px;
        display: flex;
        gap: 10px;
    }

    .text-danger {
        color: #dc3545;
    }
</style>

<div class="edit-container">
    <h2 class="edit-title">Editar Cliente</h2>

    <form method="post">
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <input type="hidden" asp-for="Cliente.Id" />

        <div class="form-group">
            <label asp-for="Cliente.Nome">Nome:</label>
            <input asp-for="Cliente.Nome" class="form-control" />
            <span asp-validation-for="Cliente.Nome" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="Cliente.Email">E-mail:</label>
            <input asp-for="Cliente.Email" class="form-control" />
            <span asp-validation-for="Cliente.Email" class="text-danger"></span>
        </div>

        <div class="action-buttons">
            <input type="submit" value="Salvar" class="btn btn-outline-azul-escuro" />
            <a asp-page="./Index" class="btn btn-outline-azul-escuro">Voltar</a>
        </div>
    </form>
</div>
